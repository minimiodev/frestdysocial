# Database (Supabase PostgreSQL)
# Hỗ trợ Supavisor connection pooler (Session mode trên port 5432 hoặc Transaction mode trên port 6543)
DATABASE_URL="postgresql://postgres:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Supabase Webhook & Realtime (Client-side)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Cloudflare R2 Storage (S3 Compatible API)
R2_ENDPOINT="https://[CLOUDFLARE_ACCOUNT_ID].r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="frest-storage"
NEXT_PUBLIC_R2_PUBLIC_URL="https://pub-[xxxx].r2.dev"

# Authentication (JWT Cookie)
JWT_SECRET="generate-a-secure-random-secret-key-here"

# SMTP Mailer ( Gmail or Resend )
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="dungflows@gmail.com"
